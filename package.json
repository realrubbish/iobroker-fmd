{
  "name": "iobroker.fmd",
  "version": "0.0.1",
  "description": "Ring FMD devices via ioBroker",
  "author": "tschnurre",
  "license": "MIT",
  "keywords": [
    "iobroker",
    "fmd",
    "find-my-device"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/realrubbish/iobroker-fmd"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.7.9",
    "hash-wasm": "^4.12.0"
  },
  "devDependencies": {
    "@emotion/cache": "^11.13.0",
    "@emotion/react": "^11.14.0",
    "@iobroker/adapter-dev": "^1.0.0",
    "@iobroker/adapter-react-v5": "^8.2.7",
    "@iobroker/eslint-config": "^1.0.0",
    "@iobroker/json-config": "^8.0.0",
    "@iobroker/testing": "^5.0.0",
    "@types/axios": "^0.14.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "json5": "^2.2.3",
    "mocha": "^11.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "~5.9.0",
    "vite": "^5.4.0"
  },
  "scripts": {
    "build": "npm run build:tsc && npm run build:admin",
    "build:tsc": "tsc --build",
    "build:admin": "node scripts/build-admin.mjs",
    "dev:admin": "vite --config src-admin/vite.config.ts",
    "auth:smoke": "node scripts/auth-smoke.mjs",
    "postbuild": "node scripts/validate-entrypoint.js",
    "watch": "tsc --build --watch",
    "test": "npm run build:tsc && npm run test:unit",
    "test:unit": "mocha",
    "lint": "eslint src/**/*.ts"
  },
  "main": "build/main.js"
}
