# ioBroker Docker Development Environment Configuration
# Copy this file to .env and adjust values as needed

# Path to the adapter source code for hot-reload volume mount
# Defaults to current directory (relative to docker-compose files); change if your repo is elsewhere
FMD_ADAPTER_SOURCE=.

# Port for ioBroker admin interface (default: 8081)
IOBROKER_PORT=8081

# Object database language (en, de, ru, etc.)
IOBROKER_OBJECT_LANGUAGE=en

# Enable debug mode for verbose logging
DEBUG=false
